model Organization {
  id                    String  @id @default(uuid())
  name                  String
  normalizedName        String  @unique @map("normalized_name")
  legalName             String? @map("legal_name")
  orgType               String? @map("org_type")
  website               String?
  domain                String?
  description           String?
  parentOrganizationId  String? @map("parent_organization_id")
  hqCity                String? @map("hq_city")
  hqStateRegion         String? @map("hq_state_region")
  hqCountry             String? @map("hq_country")
  // industry = sector/domain the org operates in (e.g. Government/Regulatory, Market Infrastructure)
  // DISTINCT from orgType which is what kind of institution it is (e.g. regulator, exchange, bank)
  industry              String? @map("industry")
  isActive              Boolean @default(true) @map("is_active")
  createdAt             String  @default(dbgenerated("(datetime('now'))")) @map("created_at")
  updatedAt             String  @default(dbgenerated("(datetime('now'))")) @map("updated_at")

  parentOrganization    Organization?          @relation("OrgParent", fields: [parentOrganizationId], references: [id])
  childOrganizations    Organization[]         @relation("OrgParent")
  aliases               OrganizationAlias[]
  affiliations          ContactAffiliation[]
  signals               OrganizationSignal[]
  // OrganizationClassification = narrower regulatory/institutional category membership; multiple per org
  // DISTINCT from orgType (broad institutional kind) and industry (sector/domain)
  classifications        OrganizationClassification[]

  @@index([domain])
  @@index([normalizedName])
  @@map("organizations")
}

model OrganizationAlias {
  id              String  @id @default(uuid())
