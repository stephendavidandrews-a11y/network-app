generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Contact {
  id              String  @id @default(uuid())
  name            String
  title           String?
  organization    String?
  email           String?
  phone           String?
  linkedinUrl     String? @map("linkedin_url")
  twitterHandle   String? @map("twitter_handle")
  personalWebsite String? @map("personal_website")
  photoUrl        String? @map("photo_url")

  tier       Int
  categories String @default("[]")
  tags       String @default("[]")

  targetCadenceDays   Int     @default(60) @map("target_cadence_days")
  lastInteractionDate String? @map("last_interaction_date")

  relationshipStrength Float @default(0) @map("relationship_strength")
  strategicValue       Float @default(0) @map("strategic_value")

  introductionPathway     String? @map("introduction_pathway")
  connectionToHawleyOrbit String? @map("connection_to_hawley_orbit")
  whyTheyMatter           String? @map("why_they_matter")

  status String  @default("target")
  notes  String?

  // Dashboard/social fields (exist in DB, needed by page.tsx)
  contactType         String  @default("professional") @map("contact_type")
  outreachMode        String  @default("direct") @map("outreach_mode")
  accessibility       String  @default("high")
  outreachTiming      String? @map("outreach_timing")
  personalRing        String? @map("personal_ring")
  personalCadenceDays Int?    @map("personal_cadence_days")
  funnelStage         String? @map("funnel_stage")

  createdAt String @default(dbgenerated("(datetime('now'))")) @map("created_at")
  updatedAt String @default(dbgenerated("(datetime('now'))")) @map("updated_at")

  // Ingestion system fields
  source                String  @default("manual") // manual, ingestion, seed
  discoveredVia         String? @map("discovered_via") // which contact/interaction surfaced this person
  dossierCurrentVersion Int?    @map("dossier_current_version")

  interactions           Interaction[]
  signals                IntelligenceSignal[]
  outreachItems          OutreachQueue[]
  relationshipsAsA       ContactRelationship[]   @relation("ContactA")
  relationshipsAsB       ContactRelationship[]   @relation("ContactB")
  meetingPreps           MeetingPrep[]
  commitmentRecords      Commitment[]
  enrichmentResults      EnrichmentResult[]
  standingOffers         StandingOffer[]
  schedulingLeads        SchedulingLead[]
  lifeEvents             LifeEvent[]
  referencedResources    ReferencedResource[]
  dossierVersions        ContactDossier[]
  ingestionItems         IngestionItem[]
  pretexts               ContactPretext[]
  textCommStats          TextContactCommStats[]
  provenanceAsContact    ContactProvenance[]     @relation("ProvenanceContact")
  provenanceAsSource     ContactProvenance[]     @relation("ProvenanceSource")
  friendRelationshipsA   FriendRelationship[]    @relation("FriendA")
  friendRelationshipsB   FriendRelationship[]    @relation("FriendB")
  personalActivities     PersonalActivity[]
  personalGroupMemberships PersonalGroupMember[]
  personalInterests      PersonalInterest[]
  socialPlanAttendees    SocialPlanAttendee[]
  textExtractionProfiles TextExtractionProfile[]
  profileSignals         ContactProfileSignal[]
  textVoiceProfiles      TextVoiceProfile[]
  socialEventAttendees   SocialEventAttendee[]
  textMessages           TextMessage[]
  contentItemsAuthored   ContentItem[]           @relation("ContentAuthor")
  extractionsAsPrimary   ContentExtraction[]     @relation("ExtractionContact")
  extractionsAsSecond    ContentExtraction[]     @relation("ExtractionSecondContact")
  draftCorrections       DraftCorrection[]
  podcastsAsHost         Podcast[]               @relation("PodcastHost")
  podcastsAsProducer     Podcast[]               @relation("PodcastProducer")
  podcastOutreach        PodcastOutreach[]
  contactInterests       ContactInterest[]
  affiliations           ContactAffiliation[]

  @@index([tier])
  @@index([status])
  @@index([lastInteractionDate])
  @@map("contacts")
}

model Interaction {
  id        String  @id @default(uuid())
  contactId String  @map("contact_id")
  type      String
  date      String  @default(dbgenerated("(date('now'))"))
  summary   String?

  commitments          String @default("[]")
  newContactsMentioned String @default("[]") @map("new_contacts_mentioned")

  followUpRequired      Boolean @default(false) @map("follow_up_required")
  followUpDescription   String? @map("follow_up_description")
  followUpCompleted     Boolean @default(false) @map("follow_up_completed")
  followUpCompletedDate String? @map("follow_up_completed_date")

  // Relationship intelligence fields
  sentiment         String? // warm, neutral, transactional, tense, enthusiastic
  relationshipDelta String? @map("relationship_delta") // strengthened, maintained, weakened, new
  relationshipNotes String? @map("relationship_notes") // personal details, rapport observations
  topicsDiscussed   String  @default("[]") @map("topics_discussed") // JSON array of specific topics

  source            String  @default("manual")
  sourceIngestionId String? @map("source_ingestion_id")
  sourceSystem      String? @map("source_system")
  sourceId          String? @map("source_id")
  createdAt         String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  contact           Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ingestionItem     IngestionItem? @relation(fields: [sourceIngestionId], references: [id])
  commitmentRecords Commitment[]

  @@index([contactId, date(sort: Desc)])
  @@index([sourceSystem, sourceId])
  @@map("interactions")
}

model IntelligenceSignal {
  id                String  @id @default(uuid())
  contactId         String  @map("contact_id")
  signalType        String  @map("signal_type")
  title             String
  description       String?
  sourceUrl         String? @map("source_url")
  sourceName        String? @map("source_name")
  detectedAt        String  @default(dbgenerated("(datetime('now'))")) @map("detected_at")
  outreachHook      String? @map("outreach_hook")
  hookUsed          Boolean @default(false) @map("hook_used")
  relevanceScore    Float   @default(5.0) @map("relevance_score")
  sourceIngestionId String? @map("source_ingestion_id")
  sourceSystem      String? @map("source_system")
  sourceId          String? @map("source_id")
  sourceClaimId     String? @map("source_claim_id")
  createdAt         String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  contact       Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ingestionItem IngestionItem?  @relation(fields: [sourceIngestionId], references: [id])
  outreachItems OutreachQueue[]

  @@index([contactId, detectedAt(sort: Desc)])
  @@index([detectedAt(sort: Desc)])
  @@index([sourceSystem, sourceId, sourceClaimId])
  @@map("intelligence_signals")
}

model Event {
  id                     String  @id @default(uuid())
  name                   String
  organizer              String?
  location               String?
  dateStart              String? @map("date_start")
  dateEnd                String? @map("date_end")
  eventUrl               String? @map("event_url")
  eventType              String? @map("event_type")
  topicRelevanceScore    Float   @default(5.0) @map("topic_relevance_score")
  topics                 String  @default("[]")
  hasSpeakingOpportunity Boolean @default(false) @map("has_speaking_opportunity")
  cfpDeadline            String? @map("cfp_deadline")
  cfpUrl                 String? @map("cfp_url")
  cfpStatus              String  @default("not_applicable") @map("cfp_status")
  abstractDraft          String? @map("abstract_draft")
  contactsAttending      String  @default("[]") @map("contacts_attending")
  contactsSpeaking       String  @default("[]") @map("contacts_speaking")
  preEventOutreachSent   Boolean @default(false) @map("pre_event_outreach_sent")
  postEventFollowupSent  Boolean @default(false) @map("post_event_followup_sent")
  attending              Boolean @default(false)
  speaking               Boolean @default(false)
  notes                  String?
  createdAt              String  @default(dbgenerated("(datetime('now'))")) @map("created_at")
  updatedAt              String  @default(dbgenerated("(datetime('now'))")) @map("updated_at")

  outreachItems      OutreachQueue[]
  contentExtractions ContentExtraction[]
  discoveredEvents   DiscoveredEvent[]

  @@index([dateStart])
  @@map("events")
}

model OutreachQueue {
  id                 String  @id @default(uuid())
  contactId          String  @map("contact_id")
  triggerType        String  @map("trigger_type")
  triggerDescription String  @map("trigger_description")
  signalId           String? @map("signal_id")
  eventId            String? @map("event_id")
  priority           Int     @default(3)
  draftSubject       String? @map("draft_subject")
  draftBody          String? @map("draft_body")
  draftFormat        String  @default("email") @map("draft_format")
  aiModelUsed        String? @map("ai_model_used")
  contextPackage     String? @map("context_package")
  status             String  @default("queued")
  originalDraft      String? @map("original_draft")
  finalText          String? @map("final_text")
  wasEdited          Boolean @default(false) @map("was_edited")
  createdAt          String  @default(dbgenerated("(datetime('now'))")) @map("created_at")
  reviewedAt         String? @map("reviewed_at")
  sentAt             String? @map("sent_at")
  deferredUntil      String? @map("deferred_until")
  notes              String?

  contact Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  signal  IntelligenceSignal? @relation(fields: [signalId], references: [id])
  event   Event?              @relation(fields: [eventId], references: [id])

  @@index([status, priority])
  @@index([contactId, createdAt(sort: Desc)])
  @@map("outreach_queue")
}

model ContactRelationship {
  id                String  @id @default(uuid())
  contactAId        String  @map("contact_a_id")
  contactBId        String  @map("contact_b_id")
  relationshipType  String? @map("relationship_type")
  strength          Int     @default(3)
  source            String  @default("manual")
  notes             String?
  // Ingestion observation tracking
  observationSource String? @map("observation_source") // "Jerry mentioned during coffee 3/1"
  observationCount  Int     @default(1) @map("observation_count")
  lastObserved      String? @map("last_observed")
  sourceSystem      String? @map("source_system")
  sourceId          String? @map("source_id")
  createdAt         String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  contactA Contact @relation("ContactA", fields: [contactAId], references: [id], onDelete: Cascade)
  contactB Contact @relation("ContactB", fields: [contactBId], references: [id], onDelete: Cascade)

  @@unique([contactAId, contactBId])
  @@index([contactAId])
  @@index([contactBId])
  @@map("contact_relationships")
}

model DailyBriefing {
  id          String @id @default(uuid())
  date        String @unique @default(dbgenerated("(date('now'))"))
  content     String
  generatedAt String @default(dbgenerated("(datetime('now'))")) @map("generated_at")

  @@map("daily_briefings")
}

model AppSetting {
  key       String @id
  value     String
  updatedAt String @default(dbgenerated("(datetime('now'))")) @map("updated_at")

  @@map("app_settings")
}

model MeetingPrep {
  id              String  @id @default(uuid())
  date            String
  contactId       String  @map("contact_id")
  calendarEventId String? @map("calendar_event_id")
  meetingTitle    String? @map("meeting_title")
  briefContent    String  @map("brief_content")
  generatedAt     String  @default(dbgenerated("(datetime('now'))")) @map("generated_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([contactId, date])
  @@map("meeting_preps")
}

model CalendarCache {
  id           String @id @default(uuid())
  date         String @unique
  calendarData String @map("calendar_data")
  meetingCount Int    @default(0) @map("meeting_count")
  fetchedAt    String @default(dbgenerated("(datetime('now'))")) @map("fetched_at")

  @@map("calendar_cache")
}

model Commitment {
  id                   String  @id @default(uuid())
  interactionId        String  @map("interaction_id")
  contactId            String  @map("contact_id")
  description          String
  dueDate              String? @map("due_date")
  fulfilled            Boolean @default(false)
  fulfilledDate        String? @map("fulfilled_date")
  fulfilledNotes       String? @map("fulfilled_notes")
  reminderSnoozedUntil String? @map("reminder_snoozed_until")
  createdAt            String  @default(dbgenerated("(datetime('now'))")) @map("created_at")
  sourceSystem         String? @map("source_system")
  sourceId             String? @map("source_id")
  sourceClaimId        String? @map("source_claim_id")
  direction            String?
  kind                 String?
  firmness             String?

  interaction Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([fulfilled, dueDate])
  @@index([sourceSystem, sourceId])
  @@map("commitments")
}

model OrganizationDomain {
  id           String  @id @default(uuid())
  organization String  @unique
  domain       String?
  resolvedBy   String  @default("manual") @map("resolved_by")
  confidence   String  @default("high")
  notes        String?
  createdAt    String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  @@map("organization_domains")
}

model EnrichmentResult {
  id          String  @id @default(uuid())
  contactId   String  @map("contact_id")
  source      String  @default("hunter")
  email       String?
  score       Int?
  domain      String?
  rawResponse String? @map("raw_response")
  status      String  @default("pending")
  reviewedAt  String? @map("reviewed_at")
  createdAt   String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([status])
  @@map("enrichment_results")
}

// ── Ingestion System ──

model IngestionItem {
  id              String  @id @default(uuid())
  source          String // email, imessage_auto, ios_shortcut, voice, signal_forward, manual
  itemType        String  @map("item_type") // interaction, intelligence_signal, scheduling, irrelevant
  rawContent      String  @map("raw_content")
  transcript      String?
  contactId       String? @map("contact_id")
  contactHint     String? @map("contact_hint")
  extraction      String // JSON: full IngestionExtraction
  manifest        String? // JSON: list of all records created on confirm (for undo)
  status          String  @default("pending") // pending, confirmed, edited, dismissed, auto_handled
  sensitivityFlag Boolean @default(false) @map("sensitivity_flag")
  contentHash     String? @map("content_hash")
  threadId        String? @map("thread_id") // iMessage thread ID for dedup
  clusterId       String? @map("cluster_id") // links related items for grouped review
  dismissReason   String? @map("dismiss_reason")
  confidence      Float? // system's confidence in auto-handling (0-1)
  autoHandled     Boolean @default(false) @map("auto_handled")
  createdAt       String  @default(dbgenerated("(datetime('now'))")) @map("created_at")
  reviewedAt      String? @map("reviewed_at")

  contact         Contact?             @relation(fields: [contactId], references: [id])
  interactions    Interaction[]
  signals         IntelligenceSignal[]
  learningSignals LearningSignal[]

  @@index([status])
  @@index([contactId])
  @@index([createdAt])
  @@index([clusterId])
  @@index([contentHash])
  @@map("ingestion_items")
}

model StandingOffer {
  id                  String  @id @default(uuid())
  contactId           String  @map("contact_id")
  description         String
  offeredBy           String  @map("offered_by") // 'me' or 'them'
  originalWords       String  @map("original_words")
  sourceInteractionId String? @map("source_interaction_id")
  sourceIngestionId   String? @map("source_ingestion_id")
  active              Boolean @default(true)
  sourceSystem        String? @map("source_system")
  sourceId            String? @map("source_id")
  createdAt           String  @default(dbgenerated("(datetime('now'))")) @map("created_at")
  usedAt              String? @map("used_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([active])
  @@index([sourceSystem, sourceId])
  @@map("standing_offers")
}

model SchedulingLead {
  id                String  @id @default(uuid())
  contactId         String  @map("contact_id")
  description       String
  originalWords     String? @map("original_words")
  timeframe         String? // "April", "after recess", "next quarter"
  resolvedDate      String? @map("resolved_date") // system's best guess at when to surface
  status            String  @default("open") // open, scheduled, stale, auto_resolved
  linkedEventId     String? @map("linked_event_id")
  sourceIngestionId String? @map("source_ingestion_id")
  sourceSystem      String? @map("source_system")
  sourceId          String? @map("source_id")
  createdAt         String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([status])
  @@index([resolvedDate])
  @@index([sourceSystem, sourceId])
  @@map("scheduling_leads")
}

model LifeEvent {
  id                String  @id @default(uuid())
  contactId         String  @map("contact_id")
  description       String
  eventType         String  @default("custom") @map("event_type")
  person            String // who the event is about (the contact or someone in their life)
  eventDate         String? @map("event_date")
  recurring         Boolean @default(false) // birthdays, anniversaries
  sourceIngestionId String? @map("source_ingestion_id")
  sourceSystem      String? @map("source_system")
  sourceId          String? @map("source_id")
  createdAt         String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([eventDate])
  @@index([sourceSystem, sourceId])
  @@map("life_events")
}

model ReferencedResource {
  id                String  @id @default(uuid())
  contactId         String? @map("contact_id")
  description       String
  resourceType      String  @map("resource_type") // paper, article, podcast, document, book, other
  url               String?
  action            String  @default("reference_only") // they_will_send, i_should_read, i_will_send, reference_only
  sourceIngestionId String? @map("source_ingestion_id")
  sourceSystem      String? @map("source_system")
  sourceId          String? @map("source_id")
  sourceClaimId     String? @map("source_claim_id")
  createdAt         String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  contact Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([sourceSystem, sourceId, sourceClaimId])
  @@map("referenced_resources")
}

model ContactDossier {
  id                  String  @id @default(uuid())
  contactId           String  @map("contact_id")
  version             Int     @default(1)
  content             String // full dossier text (structured markdown)
  updatedBy           String  @map("updated_by") // 'incremental' or 'full_resynthesis'
  sourceInteractionId String? @map("source_interaction_id")
  createdAt           String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, version])
  @@index([contactId, version])
  @@map("contact_dossiers")
}

model LearningSignal {
  id              String  @id @default(uuid())
  ingestionItemId String  @map("ingestion_item_id")
  action          String // confirmed, dismissed, edited, auto_override
  editDetails     String? @map("edit_details") // JSON: what was changed
  dismissReason   String? @map("dismiss_reason")
  teachMeResponse String? @map("teach_me_response")
  createdAt       String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  ingestionItem IngestionItem @relation(fields: [ingestionItemId], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([createdAt])
  @@map("learning_signals")
}

model ContactPretext {
  id          String  @id @default(uuid())
  contactId   String  @map("contact_id")
  pretextType String  @map("pretext_type")
  hook        String
  strength    String  @default("medium")
  validFrom   String? @map("valid_from")
  validUntil  String? @map("valid_until")
  sourceId    String? @map("source_id")
  sourceType  String? @map("source_type")
  used        Boolean @default(false)
  createdAt   String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([used])
  @@index([validUntil])
  @@map("contact_pretexts")
}

model ContactProvenance {
  id                  String  @id @default(uuid())
  contactId           String  @map("contact_id")
  sourceContactId     String? @map("source_contact_id")
  type                String
  eventId             String? @map("event_id")
  sourceInteractionId String? @map("source_interaction_id")
  sourceIngestionId   String? @map("source_ingestion_id")
  notes               String?
  createdAt           String  @default(dbgenerated("(datetime('now'))")) @map("created_at")
  sourceSystem        String? @map("source_system")
  sourceId            String? @map("source_id")
  sourceClaimId       String? @map("source_claim_id")

  contact       Contact @relation("ProvenanceContact", fields: [contactId], references: [id], onDelete: Cascade)
  sourceContact Contact? @relation("ProvenanceSource", fields: [sourceContactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([sourceContactId])
  @@index([contactId, sourceContactId])
  @@index([sourceSystem, sourceId, sourceClaimId])
  @@map("contact_provenance")
}

model TextContactCommStats {
  id                          String  @id @default(uuid())
  contactId                   String? @map("contact_id")
  phoneNumber                 String  @unique @map("phone_number")
  totalWeightedScore          Float   @default(0) @map("total_weighted_score")
  totalMessages               Int     @default(0) @map("total_messages")
  messagesSent                Int     @default(0) @map("messages_sent")
  messagesReceived            Int     @default(0) @map("messages_received")
  firstMessageDate            String? @map("first_message_date")
  lastMessageDate             String? @map("last_message_date")
  avgMessagesPerWeek          Float   @default(0) @map("avg_messages_per_week")
  last30DayCount              Int     @default(0) @map("last_30_day_count")
  last90DayCount              Int     @default(0) @map("last_90_day_count")
  reciprocityRatio            Float   @default(0) @map("reciprocity_ratio")
  responseLatencyAvg          Float?  @map("response_latency_avg")
  trend                       String  @default("stable")
  participationRateGroupChats Float   @default(0) @map("participation_rate_group_chats")
  droppedBall                 Boolean @default(false) @map("dropped_ball")
  droppedBallSince            String? @map("dropped_ball_since")
  appleContactName            String? @map("apple_contact_name")
  triageStatus                String? @map("triage_status")
  lastComputed                String  @default(dbgenerated("(datetime('now'))")) @map("last_computed")

  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([droppedBall])
  @@index([totalWeightedScore(sort: Desc)])
  @@map("text_contact_comm_stats")
}

model FriendRelationship {
  id               String  @id @default(uuid())
  contactAId       String  @map("contact_a_id")
  contactBId       String  @map("contact_b_id")
  relationshipType String  @default("know_each_other") @map("relationship_type")
  source           String  @default("manual")
  notes            String?
  createdAt        String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  contactA Contact @relation("FriendA", fields: [contactAId], references: [id], onDelete: Cascade)
  contactB Contact @relation("FriendB", fields: [contactBId], references: [id], onDelete: Cascade)

  @@map("friend_relationships")
}

model PersonalActivity {
  id             String  @id @default(uuid())
  contactId      String  @map("contact_id")
  activity       String
  frequency      String  @default("occasional")
  confidence     String  @default("medium")
  source         String  @default("manual")
  lastMentioned  String? @map("last_mentioned")
  sourceSystem   String? @map("source_system")
  sourceId       String? @map("source_id")
  sourceClaimId  String? @map("source_claim_id")
  createdAt      String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([sourceSystem, sourceId, sourceClaimId])
  @@map("personal_activities")
}

model PersonalGroup {
  id          String  @id @default(uuid())
  name        String
  description String?
  createdAt   String  @default(dbgenerated("(datetime('now'))")) @map("created_at")

  members PersonalGroupMember[]

  @@map("personal_groups")
}

model PersonalGroupMember {
  id        String @id @default(uuid())
  groupId   String @map("group_id")
  contactId String @map("contact_id")
  createdAt String @default(dbgenerated("(datetime('now'))")) @map("created_at")

  group   PersonalGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contact Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("personal_group_members")
}

model PersonalInterest {
  id             String  @id @default(uuid())
  contactId      String  @map("contact_id")
  interest       String
