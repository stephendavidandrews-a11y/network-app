  contact         Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([organizationId])
  @@index([sourceSystem, sourceId, sourceClaimId])
  @@map("contact_affiliations")
}

model OrganizationSignal {
  id              String  @id @default(uuid())
  organizationId  String  @map("organization_id")
  signalType      String  @map("signal_type")
  title           String?
  description     String
  confidence      Float?
  observedAt      String? @map("observed_at")
  sourceSystem    String? @map("source_system")
  sourceId        String? @map("source_id")
  sourceClaimId   String? @map("source_claim_id")
  resolutionSource String? @map("resolution_source")
  relatedOrg       String? @map("related_org")
  relationshipType String? @map("relationship_type")
  createdAt       String  @default(dbgenerated("(datetime('now'))")) @map("created_at")
  updatedAt       String  @default(dbgenerated("(datetime('now'))")) @map("updated_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([signalType])
  @@index([sourceSystem, sourceId, sourceClaimId])
  @@map("organization_signals")
}

// OrganizationClassification = narrower regulatory/institutional category membership
// DISTINCT from orgType (broad institutional kind) and industry (sector/domain)
// Examples: DCO, DCM, SEF, SDR, FCM, CPO, CTA, SD, MSP, SRO, federal_agency, etc.
// An org may have multiple active classifications.
model OrganizationClassification {
  id                    String  @id @default(uuid())
  organizationId        String  @map("organization_id")
  classificationType    String  @map("classification_type")
  classificationSystem  String  @map("classification_system")
  isActive              Boolean @default(true) @map("is_active")
  effectiveDate         String? @map("effective_date")
  endDate               String? @map("end_date")
  createdAt             String  @default(dbgenerated("(datetime('now'))")) @map("created_at")
  updatedAt             String  @default(dbgenerated("(datetime('now'))")) @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, classificationType, classificationSystem])
  @@index([classificationType])
  @@index([classificationSystem])
  @@index([organizationId])
  @@map("organization_classifications")
}
